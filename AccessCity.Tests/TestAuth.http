@AccessCity.API_HostAddress = http://localhost:5005

### health check
GET {{AccessCity.API_HostAddress}}/health
Accept: application/json

### register user
POST {{AccessCity.API_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123",
  "fullName": "Test User"
}

### login user
# @name login
POST {{AccessCity.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

### read token
@token = {{login.response.body.token}}

### test the endpoint, if 204 returned it is a success
GET {{AccessCity.API_HostAddress}}/api/tiles/1/1/1.pbf
Authorization: Bearer {{token}}

### forgot password
POST {{AccessCity.API_HostAddress}}/api/auth/forgot-password
Content-Type: application/json

{
  "email": "test@example.com"
}

### reset password
# you will need to replace the token value below with the 
# actual reset token generated by the forgot password endpoint.
POST {{AccessCity.API_HostAddress}}/api/auth/reset-password
Content-Type: application/json

{
  "email": "test@example.com",
  "token": "YOUR_RESET_TOKEN_HERE",
  "newPassword": "newPassword123"
}

EXPO_PUBLIC_API_HOST=192.168.x.x
EXPO_PUBLIC_API_PORT=8080
# Optional: default map centre when GPS unavailable (defaults to Birmingham)
# EXPO_PUBLIC_DEFAULT_MAP_LAT=52.4862
# EXPO_PUBLIC_DEFAULT_MAP_LNG=-1.8904
# Optional: Sentry (errors + performance). Leave unset for local dev without reporting.
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

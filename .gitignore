# .gitignore for .NET and Expo/React Native
bin/
obj/
*.user
*.userosscache
*.sln.doccache

# Node.js
node_modules/
.expo/
dist/
build/
coverage/
**/coverage/
test-results/
**/test-results/
playwright-report/
**/playwright-report/

# Expo / React Native
.expo-shared/
.expo/
web-build/
*.jks
*.p12
*.key
*.mobileprovision
*.orig.*

# Environment
.env
.env.*
!.env.example
!**/.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS
.DS_Store
Thumbs.db

# SQLTools settings ignore
.vscode/settings.json
# Data files
*.osm
*.pbf
data/osm/
data/route-graph-artifacts/

# Build / Cache files
__pycache__/
build_error.txt

# Scripts
scripts/

*.txt
!tools/accessibility_vision/requirements-l20.txt
AccessCity.API/Logs/

# Copy this file to .env and change the password for production use
DB_PASSWORD=AccessCity_Dev_2026!

# Docker Compose API settings
JWT_SECRET=AccessCity_Secret_Key_For_Dev_2026_Placeholder
JWT_PREVIOUS_KEYS=
REDIS_CONNECTION=redis:6379
MESSAGING_USE_KAFKA=false
Kafka__MaxProcessingAttempts=3
Kafka__RetryDelaySeconds=5
API_OSM_WORKER_ENABLED=true
API_ROUTING_WORKER_ENABLED=false
API_TILE_WORKER_ENABLED=true
OsmImport__FilePath=/app/osm/test-network.osm
OsmImport__ImportOnStartup=true
OsmImport__UsePostgresCopy=true
OsmImport__BulkCopyBatchSize=20000
Routing__DispatchJobsToWorker=false
Routing__RequireRouteGraphForReadiness=false
Routing__RouteGraphCacheTtlSeconds=300
RiskScoring__CacheFillTimeoutSeconds=5

# AI assist. Keep route decisions deterministic; these providers only generate review-only text/candidates.
AiEnrichment__Enabled=true
AiEnrichment__Provider=local-rules
# To use Nebius in Docker Compose, set AiEnrichment__Provider=nebius and provide NEBIUS_API_KEY.
NEBIUS_API_KEY=
AiEnrichment__NebiusBaseUrl=https://api.tokenfactory.nebius.com/v1
AiEnrichment__NebiusModel=openai/gpt-oss-120b-fast
AiEnrichment__NebiusHighQualityModel=Qwen/Qwen3.5-397B-A17B-fast
AiEnrichment__NebiusTimeoutSeconds=8
AiEnrichment__NebiusMaxTokens=700
AiEnrichment__NebiusEnableImageInputs=false
AiEnrichment__VisionModelEndpoint=
AiEnrichment__VisionModelTimeoutSeconds=5
AiEnrichment__VisionModelMinimumConfidence=0.55
OPENAI_API_KEY=

HotPathWarmup__Enabled=true
HotPathWarmup__InitialDelaySeconds=2
HotPathWarmup__IntervalSeconds=300
HotPathWarmup__MaxPoints=192
HotPathWarmup__BucketCorridorRadiusSteps=20
HotPathWarmup__BucketCorridorStepDegrees=0.0001
HotPathWarmup__RiskRadiusMetres=500
HotPathWarmup__PoiRadiusMetres=750
HotPathWarmup__Points__0__Name=birmingham-core
HotPathWarmup__Points__0__Lat=52.4862
HotPathWarmup__Points__0__Lng=-1.8904
Routing__RouteGraphShardSizeDegrees=0.01
Postgres__UseStartupSessionParameters=false
Postgres__StatementTimeoutMs=15000
Postgres__IdleInTransactionSessionTimeoutMs=30000
Postgres__MaxPoolSize=100
RateLimiting__Global__PermitLimit=100
RateLimiting__Global__QueueLimit=10
Cors__AllowedOrigins__0=http://localhost:8081
Secrets__KeyPerFilePath=/mnt/secrets
ACCESSCITY_SECRETS_PATH=/mnt/secrets

# Optional: use a hosted PostgreSQL database instead of appsettings/docker defaults.
# DATABASE_URL=postgres://accesscity:accesscity123@localhost:5432/accesscitydb?sslmode=disable

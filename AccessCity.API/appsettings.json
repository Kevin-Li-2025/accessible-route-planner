{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/accesscity-api-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=accesscitydb;Username=accesscity;Password=accesscity123"
  },
  "Postgres": {
    "AutoMigrate": true,
    "AutoSchemaMaintenance": true,
    "CommandTimeoutSeconds": 30,
    "UseStartupSessionParameters": false,
    "StatementTimeoutMs": 15000,
    "IdleInTransactionSessionTimeoutMs": 30000,
    "MaxPoolSize": 100,
    "MinPoolSize": 0,
    "DbContextPoolSize": 128
  },
  "Routing": {
    "MaxConcurrentComputations": 4,
    "SyncSafePathTimeoutSeconds": 4,
    "ComputationQueueTimeoutSeconds": 2,
    "JobComputationQueueTimeoutSeconds": 30,
    "RouteJobDispatchConcurrency": 2,
    "HazardQueryPaddingMetres": 250,
    "MaxHazardsPerRequest": 500,
    "MaxRiskQueryRadiusMetres": 2500,
    "MaxRouteGraphEdges": 20000,
    "AsyncFirstForCacheMiss": false,
    "AsyncFirstCacheProbeMilliseconds": 150,
    "DispatchJobsToWorker": false,
    "RouteGraphWarmupEnabled": false,
    "RouteGraphWarmupDelaySeconds": 15,
    "RouteGraphWarmupIntervalSeconds": 240,
    "RouteGraphWarmupRoutes": [
      {
        "Name": "birmingham-core",
        "StartLat": 52.4862,
        "StartLng": -1.8904,
        "EndLat": 52.4862,
        "EndLng": -1.8894
      }
    ],
    "RequireRouteGraphForReadiness": false,
    "RouteGraphCacheTtlSeconds": 300,
    "RouteGraphShardSizeDegrees": 0.01,
    "RouteGraphPrepartitionedShardsEnabled": false,
    "RouteGraphMaxPrepartitionedShardCount": 64,
    "RouteGraphMinEdgesPerPrepartitionedShard": 250,
    "RouteGraphPackedArtifactsEnabled": true,
    "RouteGraphDistributedLoadCoalescingEnabled": true,
    "RouteGraphDistributedLoadLockTtlSeconds": 8,
    "RouteGraphDistributedLoadWaitMilliseconds": 3500,
    "DistributedCoalescingEnabled": true,
    "DistributedCoalescingLockTtlSeconds": 6,
    "DistributedCoalescingResultTtlSeconds": 10,
    "DistributedCoalescingWaitMilliseconds": 3500,
    "DistributedCoalescingPollMilliseconds": 25
  },
  "RiskScoring": {
    "CacheTtlSeconds": 30,
    "CacheCoordinatePrecision": 4,
    "CacheRadiusBucketMetres": 50,
    "ExternalSignalBudgetMilliseconds": 350,
    "RealtimeExternalSignalsEnabled": true
  },
  "AiEnrichment": {
    "Enabled": true,
    "Provider": "local-rules",
    "DuplicateRadiusMetres": 25,
    "MinimumCandidateConfidence": 0.35,
    "AllowRouteDecisionInfluence": false,
    "MaxExplanationWarnings": 5
  },
  "Geocoding": {
    "UpstreamAttempts": 1,
    "RetryDelayMilliseconds": 100
  },
  "HealthChecks": {
    "ReadinessCacheMilliseconds": 2000,
    "ReadinessBackgroundRefreshMilliseconds": 2000
  },
  "OsmImport": {
    "FilePath": "london.osm;birmingham.osm",
    "ImportOnStartup": false,
    "ReplaceExisting": true
  },
  "Messaging": {
    "UseKafka": false
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "accesscity-workers",
    "TopicPrefix": "accesscity_",
    "MaxProcessingAttempts": 3,
    "RetryDelaySeconds": 5,
    "TopicAdminTimeoutSeconds": 3,
    "TopicWarmupTimeoutSeconds": 10,
    "RetryTopicSuffix": ".retry",
    "DeadLetterTopicSuffix": ".dlq"
  },
  "ExternalApis": {
    "CircuitBreaker": {
      "FailureThreshold": 3,
      "BreakSeconds": 30,
      "QueueTimeoutMilliseconds": 50
    },
    "Osrm": {
      "TimeoutSeconds": 3,
      "MaxConcurrentRequests": 32
    },
    "Overpass": {
      "TimeoutSeconds": 5,
      "MaxConcurrentRequests": 4,
      "RealtimeHazardsEnabled": true,
      "HazardFetchBudgetSeconds": 12
    },
    "UkPolice": {
      "TimeoutSeconds": 2,
      "MaxConcurrentRequests": 8
    },
    "Nominatim": {
      "TimeoutSeconds": 2
    },
    "GooglePlaces": {
      "TimeoutSeconds": 6
    },
    "OpenWeather": {
      "TimeoutSeconds": 5
    },
    "Environmental": {
      "TimeoutSeconds": 3,
      "MaxConcurrentRequests": 4
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 30000,
      "QueueLimit": 0
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Secrets": {
    "KeyPerFilePath": "/mnt/secrets"
  },
  "Workers": {
    "OsmImport": {
      "Enabled": true
    },
    "Routing": {
      "Enabled": false
    },
    "TileWarming": {
      "Enabled": true
    }
  },
  "Jwt": {
    "Key": "AccessCity_Secret_Key_Secure_Long_Enough_For_HS512_2026_Development_Phase_64_Bytes_Long_!!!_STILL_ENFORCING_LENGTH_HE_HE",
    "Issuer": "AccessCity.API",
    "Audience": "AccessCity.App",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "AllowedHosts": "*"
}
